generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model AiVersion {
  id        Int      @id @default(autoincrement())
  instance  String   @db.VarChar(255)
  version   Int
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@map("ai_versions")
  @@schema("sistema")

  @@unique([instance, version])
  @@index([instance])
  @@index([createdAt])
}

model AiTemplateBase {
  id             Int      @id @default(autoincrement())
  templateKey    String   @db.VarChar(100)
  templateName   String   @db.VarChar(255)
  version        Int
  templateContent String
  contentType    String   @default("json-template") @db.VarChar(50)
  sourcePath     String?  @db.VarChar(255)
  isCurrent      Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @db.Timestamp(6)

  @@map("ai_template_bases")
  @@schema("sistema")

  @@unique([templateKey, version])
  @@index([templateKey, isCurrent])
  @@index([isCurrent])
}

datasource db {
  provider = "postgresql"
  schemas  = ["sistema"]
}

model news {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String
  type        String    @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  @@schema("sistema")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  userName  String   @db.VarChar(255)
  action    String
  target    String?
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@map("system_logs")
  @@schema("sistema")

  @@index([createdAt]) // Acelera muito o filtro por data e ordenação
  @@index([userName])  // Acelera busca por nome
}
