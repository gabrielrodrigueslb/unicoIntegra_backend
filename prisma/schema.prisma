generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model news {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String
  type        String    @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}
