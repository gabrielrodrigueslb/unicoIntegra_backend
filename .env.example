PORT=4000
HOST=0.0.0.0
DBHOST=127.0.0.1
DBPORT=5432
DBUSER=postgres
DBPASSWORD=postgres
DB_DATABASE=unico_integra
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/unico_integra
AI_URA_AUDIT_ENABLED=true
AI_URA_AUDIT_HOUR=3
AI_URA_AUDIT_MINUTE=0
AI_URA_AUDIT_TIMEZONE=America/Sao_Paulo
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-nano
OPENAI_REASONING_EFFORT=low
OPENAI_VERBOSITY=medium
# Por padrao o backend clona este repositorio da extensao Trier antes do build
TRIER_EXTENSION_REPO_URL=https://github.com/UnicoContato/trier_extensao.git
TRIER_EXTENSION_REPO_BRANCH=main
# Opcional: fallback para um checkout/diretorio local
TRIER_EXTENSION_TEMPLATE_DIR=
# Opcional: fallback para template externo compactado. Em Linux, prefira diretorio.
TRIER_EXTENSION_TEMPLATE_ZIP=
# Por padrao o backend clona este repositorio da extensao Inova Farma antes do build
INOVA_FARMA_EXTENSION_REPO_URL=https://github.com/UnicoContato/Extensao_inova_revisada.git
INOVA_FARMA_EXTENSION_REPO_BRANCH=main
# Opcional: fallback para um checkout/diretorio local
INOVA_FARMA_EXTENSION_TEMPLATE_DIR=
# Opcional: fallback para template externo compactado. Em Linux, prefira diretorio.
INOVA_FARMA_EXTENSION_TEMPLATE_ZIP=
# Aceita match exato e wildcard, ex: https://painel.seudominio.com,https://*.seudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://unico-integra.vercel.app
