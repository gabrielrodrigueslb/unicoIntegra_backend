{
  "name": "Trier Sistemas",
  "description": "Versao de teste para extensao de Integracoes",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Extension"
  },
  "icons": {
    "16": "logo-extensao.png",
    "48": "logo-extensao.png",
    "128": "logo-extensao.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "permissions": ["storage", "tabs", "activeTab", "webRequest", "alarms"],
  "host_permissions": [
    "https://api-sgf-gateway.triersistemas.com.br/*"
  ]
}
